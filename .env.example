# Base URL of the ebc-crm-api backend (no trailing slash).
VITE_API_BASE_URL=http://localhost:3001

# Supabase project URL — same project as the backend.
VITE_SUPABASE_URL=

# Supabase anon key — safe to expose to the browser. RLS + the backend
# protect the data; this key is only used for Auth session management.
VITE_SUPABASE_ANON_KEY=

VITE_APP_NAME=EBC Workforce CRM
VITE_APP_ENV=development
